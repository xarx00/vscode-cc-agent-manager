{
  "name": "vscode-cc-agent-manager",
  "displayName": "Claude Code Agent Manager",
  "description": "Track Claude Code agents and sessions across all your workspaces",
  "license": "MIT",
  "version": "0.5.2",
  "publisher": "KyleJamesWalker",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KyleJamesWalker/vscode-cc-agent-manager"
  },
  "keywords": [
    "claude",
    "agents",
    "ai",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "claudeAgentManager.openPanel",
        "title": "Claude: Open Agent Manager",
        "icon": "$(robot)"
      }
    ],
    "keybindings": [
      {
        "command": "claudeAgentManager.openPanel",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "claudeAgentManager.openPanel"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "npm run compile && npm run test:unit && npm run test:integration",
    "test:unit": "jest",
    "test:integration": "node ./out/test/integration/runTest.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "marked": "^17.0.4",
    "mocha": "^11.7.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
